#!/bin/sh
/bin/busybox --install -s /bin
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

echo
echo "========================================================"
echo "  BusyBox on ARMv4 -- $(uname -srm)"
echo "  $(grep -m1 "model name" /proc/cpuinfo)"
echo "========================================================"
echo

exec setsid cttyhack sh
