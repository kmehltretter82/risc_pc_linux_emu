# musl-cross-make configuration for the strict ARMv4 userspace toolchain.
TARGET = arm-linux-musleabi
OUTPUT = $(CURDIR)/output/armv4-tc-gcc8
GCC_VER = 8.5.0
GCC_CONFIG += --with-arch=armv4 --with-mode=arm --with-float=soft
GCC_CONFIG += --enable-languages=c
COMMON_CONFIG += CFLAGS="-g0 -O2" CXXFLAGS="-g0 -O2"
